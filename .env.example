# Environment Variables — P. Heiniger Design Studio
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.

# ─── Google Sheets (CMS & Leads) ──────────────────────────────────────────────
# The Google Sheet ID for CMS content (projects, services, hero experiments).
# Found in the Sheet URL: /spreadsheets/d/[THIS_ID]/edit
GOOGLE_CMS_SHEET_ID=

# The Google Sheet ID for the leads/bookings database.
GOOGLE_LEADS_SHEET_ID=

# Base64-encoded Google Cloud service account JSON key.
# Generate: base64 -i path/to/key.json (Mac) | pbcopy
# The service account must have Editor access to both sheets above.
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=

# ─── Payrexx (Swiss Payment Gateway) ──────────────────────────────────────────
# Your Payrexx instance subdomain (e.g. if your URL is meinshop.payrexx.com, use "meinshop")
PAYREXX_INSTANCE=

# Your Payrexx API secret key (found under API in Payrexx dashboard)
PAYREXX_API_KEY=

# Webhook secret for validating Payrexx payment confirmation callbacks.
# Add webhook URL in Payrexx dashboard: https://[your-domain]/api/payments/webhook
PAYREXX_WEBHOOK_SECRET=

# ─── Internal Security ────────────────────────────────────────────────────────
# Bearer token for the /api/ops/run admin endpoint (health checks & smoke tests).
# Generate a secure token: openssl rand -hex 32
OPS_ADMIN_SECRET=
