---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { LANGS, normalizeLang } from '../../lib/i18n';

export const prerender = true;

export function getStaticPaths() {
  return LANGS.map((lang) => ({ params: { lang } }));
}

const lang = normalizeLang(Astro.params.lang);
const isEn = lang === 'en';
---

<BaseLayout lang={lang} title={isEn ? 'Imprint | P. Heiniger Design' : 'Impressum | P. Heiniger Design'}>
  <main class="max-w-2xl mx-auto px-6 py-24 min-h-screen text-stone-800">
    <a href={`/${lang}`} class="text-xs uppercase tracking-widest text-stone-400 hover:text-stone-700 transition-colors mb-12 inline-block">
      ← {isEn ? 'Back' : 'Zurück'}
    </a>

    <h1 class="text-4xl font-light tracking-tight mb-12 text-stone-900">
      {isEn ? 'Imprint' : 'Impressum'}
    </h1>

    <div class="space-y-8 text-sm leading-relaxed text-stone-600">
      <section>
        <h2 class="text-xs uppercase tracking-widest text-stone-400 mb-3">
          {isEn ? 'Responsible for content' : 'Verantwortlich für den Inhalt'}
        </h2>
        <p>Pascal Heiniger<br />Design Studio<br />Andermatt, Schweiz</p>
      </section>

      <section>
        <h2 class="text-xs uppercase tracking-widest text-stone-400 mb-3">Kontakt / Contact</h2>
        <p>
          <a href="mailto:pascal@oss.studio" class="underline underline-offset-4 hover:text-stone-900 transition-colors">
            pascal@oss.studio
          </a>
        </p>
      </section>

      <section>
        <h2 class="text-xs uppercase tracking-widest text-stone-400 mb-3">
          {isEn ? 'Disclaimer' : 'Haftungsausschluss'}
        </h2>
        <p>
          {isEn
            ? 'The content of this website has been compiled with due care and to the best of our knowledge. However, we cannot guarantee its timeliness, completeness, or accuracy.'
            : 'Die Inhalte dieser Website wurden mit grösster Sorgfalt erstellt. Für die Richtigkeit, Vollständigkeit und Aktualität der Inhalte übernehmen wir keine Gewähr.'}
        </p>
      </section>
    </div>
  </main>
</BaseLayout>
